APP_NAME=First Principles Strategy OS API
DATABASE_URL=sqlite:///./world_inference.db
LLM_PROVIDER=deepseek
LLM_FALLBACK_TO_MOCK=false
LLM_REQUEST_TIMEOUT_SECONDS=120
LLM_MAX_OUTPUT_TOKENS=1800
LLM_REASONING_MAX_OUTPUT_TOKENS=2200
LLM_TEMPERATURE=0.0
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_REASONING_MODEL=gpt-5
DEEPSEEK_API_KEY=your_real_key
DEEPSEEK_CHAT_MODEL=deepseek-chat
DEEPSEEK_REASONING_MODEL=deepseek-reasoner
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEFAULT_DEMO_USER_ID=demo-admin
APP_SECRET=local-dev-secret
SESSION_EXPIRATION_HOURS=72
ENABLE_DEMO_AUTH=false
